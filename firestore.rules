rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas de DESARROLLO: permiten lectura/escritura solo con sesión autenticada.
    // Para producción, restringe por usuario (request.auth.uid).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
